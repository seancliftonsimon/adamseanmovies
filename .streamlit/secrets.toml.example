TMDB_READ_TOKEN = "your_tmdb_read_access_token"
# TMDB_API_KEY = "your_tmdb_api_key"

# Supabase/Postgres — use the SESSION POOLER URI from Supabase Connect.
# Note: the username MUST be  postgres.<project-ref>  (not just "postgres").
# Direct-connection URIs (db.<ref>.supabase.co) are IPv6-only and usually
# unreachable from Streamlit Community Cloud.
#
# Session pooler (port 5432):
DATABASE_URL = "postgresql://postgres.YOUR_PROJECT_REF:YOUR_DB_PASSWORD@aws-0-us-east-1.pooler.supabase.com:5432/postgres"
#
# Transaction pooler (port 6543) — also works:
# DATABASE_URL = "postgresql://postgres.YOUR_PROJECT_REF:YOUR_DB_PASSWORD@aws-0-us-east-1.pooler.supabase.com:6543/postgres"
